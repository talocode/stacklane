{
  "name": "@stacklane/api",
  "private": true,
  "version": "0.4.1",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "node scripts/migrate.mjs",
    "seed": "node scripts/seed.mjs",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^5.6.0",
    "@stacklane/core": "workspace:*",
    "@stacklane/storage": "workspace:*",
    "@stacklane/types": "workspace:*",
    "drizzle-orm": "^0.39.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
