# ─── Netlify deployment env vars (fill in real values in Netlify UI) ───
# Copy this to Netlify Environment Variables, do NOT commit secrets.

# Node
NODE_VERSION=22

# Server
PORT=4000
NODE_ENV=production

# Database (managed PostgreSQL e.g. Render, Aiven, Neon)
DATABASE_URL=

# Talocode Cloud public URLs
TALOCODE_BASE_URL=https://api.talocode.site
TALOCODE_WEB_URL=https://talocode.site
TALOCODE_MCP_URL=https://api.talocode.site/mcp
TALOCODE_DOCS_URL=https://docs.talocode.site

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# AI Providers (router fallback)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# GitHub (for Skills API data enrichment)
GITHUB_TOKEN=

# Skills provider (optional: set to enable provider-assisted generation)
# TALOCODE_SKILLS_PROVIDER=

# Web origin (CORS)
WEB_ORIGIN=https://talocode.site
