{
  "name": "@talocode/mcp",
  "version": "0.1.0",
  "description": "Talocode MCP bridge — connect AI agents to Talocode Cloud APIs via stdio MCP",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "talocode-mcp": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/__tests__/bridge.test.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run test && npm pack --dry-run",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.7.1",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/talocode/stacklane.git",
    "directory": "packages/talocode-mcp"
  },
  "homepage": "https://github.com/talocode/stacklane/tree/main/packages/talocode-mcp",
  "bugs": {
    "url": "https://github.com/talocode/stacklane/issues"
  },
  "keywords": [
    "talocode",
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "stdio"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}